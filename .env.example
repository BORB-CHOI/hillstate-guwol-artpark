# =============================================================
# 힐스테이트 구월아트파크 랜딩페이지 환경변수 예시
# 이 파일을 복사해 .env.local 로 저장하고 값을 채우세요.
#   cp .env.example .env.local
# (환경변수가 없어도 로컬에서는 파일 저장/콘솔 로그로 정상 동작합니다)
# =============================================================

# --- 사이트 공개 정보 (브라우저 노출됨, NEXT_PUBLIC_ 접두사) ---
NEXT_PUBLIC_SITE_URL=https://hillstate-guwol-artpark.vercel.app
NEXT_PUBLIC_PHONE=1533-0000
NEXT_PUBLIC_KAKAO_URL=https://pf.kakao.com/_gGHwX

# --- 관리자 (문의 목록 조회 /admin) ---
# 임의의 긴 문자열을 지정하세요. /admin 에서 이 값을 입력해야 목록이 보입니다.
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- 문의 DB 저장 (Upstash Redis — 서버리스, 콜드스타트 없음) ---
# Vercel > Storage 또는 Upstash 콘솔에서 Redis 생성 시 아래 값이 발급됩니다.
# Vercel Marketplace로 Upstash를 연동하면 이 변수들이 자동 주입됩니다.
# (Vercel KV를 쓰면 KV_REST_API_URL / KV_REST_API_TOKEN 도 자동 인식)
# 미설정 시 data/reservations.json 파일에 저장됩니다(개발용).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# --- 담당자 알림 — 고객에게는 알림을 보내지 않습니다 ---
# 카카오톡 "나에게 보내기"
# 알림톡 심사도 필요 없음. 최초 1회만 설정하면 됨 (README 참고).
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=http://localhost:3000/api/kakao/callback
KAKAO_REFRESH_TOKEN=
